---
export const prerender = false

import BaseLayout from '../../../layouts/BaseLayout.astro';
import { sanityFetch } from '../../../lib/sanity/client';
import { workshopAttendQuery } from '../../../lib/sanity/queries';
import { getAccessStatus, getCloseDate } from '../../../lib/workshop-access';
import PortableTextRenderer from '../../../components/blog/PortableTextRenderer.astro';
import WorkshopEmailCapture from '../../../components/islands/WorkshopEmailCapture';
import SectionFeedback from '../../../components/islands/SectionFeedback';

interface Section {
  _key: string;
  emoji?: string;
  title: string;
  sectionFeedbackUrl?: string;
  content?: any[];
}

interface WorkshopInstanceData {
  _id: string;
  title: string;
  event: string;
  token: string;
  workshopDate: string;
  accessDurationDays: number;
  forceClose: boolean;
  repoUrl: string;
  overallFeedbackUrl?: string;
  emailCaptureEnabled?: boolean;
  sections?: Section[];
}

const { token } = Astro.params;
const instance = await sanityFetch<WorkshopInstanceData | null>(workshopAttendQuery, { token }).catch(() => null);

if (!instance) {
  return Astro.redirect('/404');
}

const status = getAccessStatus(instance);
const closeDate = getCloseDate(instance);

const formatDateLong = (dateStr: string) => {
  return new Date(dateStr).toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  });
};

const formatCloseDateLong = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  });
};
---

<BaseLayout
  title={`${instance.title} | Workshop`}
  description={`Workshop materials for ${instance.title}`}
  pathname={`/workshops/attend/${token}`}
>
  {status === 'upcoming' && (
    <section class="min-h-[80vh] flex items-center">
      <div class="container py-20 md:py-32">
        <div class="max-w-3xl mx-auto text-center">
          <div class="terminal max-w-lg mx-auto mb-8 animate-fade-in">
            <div class="terminal__header">
              <div class="terminal__dots">
                <div class="terminal__dot terminal__dot--red"></div>
                <div class="terminal__dot terminal__dot--yellow"></div>
                <div class="terminal__dot terminal__dot--green"></div>
              </div>
              <span class="terminal__title">workshop.sh</span>
            </div>
            <div class="terminal__body">
              <span class="terminal__prompt">$</span>
              <span class="terminal__command"> npm run workshop --session="{instance.event}"</span>
              <div class="terminal__output">Waiting for session to begin...</div>
            </div>
          </div>

          <h1 class="text-3xl md:text-4xl lg:text-5xl font-display font-bold text-ink mb-6">
            {instance.title}
          </h1>

          <p class="text-lg text-ink-muted mb-8">
            This session opens on <span class="font-semibold text-ink">{formatDateLong(instance.workshopDate)}</span>. Check back then.
          </p>
        </div>
      </div>
    </section>
  )}

  {(status === 'closed' || status === 'force-closed') && (
    <section class="min-h-[80vh] flex items-center">
      <div class="container py-20 md:py-32">
        <div class="max-w-3xl mx-auto text-center">
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-display font-bold text-ink mb-6">
            {instance.title}
          </h1>

          <p class="text-lg text-ink-muted mb-8">
            This workshop session has ended. Materials are no longer available.
          </p>

          <a href="/workshops" class="btn-primary">
            View workshops
          </a>
        </div>
      </div>
    </section>
  )}

  {status === 'open' && (
    <>
      <!-- Hero -->
      <section class="relative overflow-hidden">
        <div class="absolute inset-0 grid-pattern opacity-50"></div>
        <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 via-teal-500/5 to-cyan-500/5"></div>

        <div class="container relative z-10 pt-20 md:pt-28 pb-16">
          <div class="max-w-4xl">
            <div class="terminal max-w-lg mb-8 animate-fade-in">
              <div class="terminal__header">
                <div class="terminal__dots">
                  <div class="terminal__dot terminal__dot--red"></div>
                  <div class="terminal__dot terminal__dot--yellow"></div>
                  <div class="terminal__dot terminal__dot--green"></div>
                </div>
                <span class="terminal__title">workshop.sh</span>
              </div>
              <div class="terminal__body">
                <span class="terminal__prompt">$</span>
                <span class="terminal__command"> npm run workshop --session="{instance.event}"</span>
                <div class="terminal__output">Session active. Loading materials...</div>
              </div>
            </div>

            <h1 class="text-3xl md:text-4xl lg:text-5xl font-display font-bold mb-6">
              <span class="block text-ink">{instance.title}</span>
            </h1>

            <div class="flex flex-wrap items-center gap-3 mb-8">
              <span class="px-3 py-1.5 text-sm font-medium bg-emerald-50 dark:bg-emerald-900/20 text-emerald-700 dark:text-emerald-400 rounded-full border border-emerald-200 dark:border-emerald-800">
                {instance.event}
              </span>
            </div>

            <a
              href={instance.repoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary text-lg px-8 py-4 group glow inline-flex items-center"
            >
              Open GitHub Repo
              <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </section>

      <!-- Email Capture -->
      {instance.emailCaptureEnabled && (
        <section class="section py-12 md:py-16">
          <div class="container">
            <div class="max-w-2xl mx-auto">
              <WorkshopEmailCapture
                client:load
                instanceSlug={instance.token}
                event={instance.event}
              />
            </div>
          </div>
        </section>
      )}

      <!-- Materials Sections -->
      {instance.sections && instance.sections.length > 0 && (
        <section class="section py-12 md:py-16">
          <div class="container">
            <div class="max-w-4xl mx-auto space-y-16">
              {instance.sections.map((section: Section) => (
                <div>
                  <div class="flex items-center gap-3 mb-2">
                    {section.emoji && (
                      <span class="text-2xl">{section.emoji}</span>
                    )}
                    <h2 class="heading-2 mb-0">{section.title}</h2>
                  </div>
                  <div class="h-px bg-edge mb-8"></div>

                  {section.content && section.content.length > 0 && (
                    <PortableTextRenderer value={section.content} />
                  )}

                  {section.sectionFeedbackUrl && (
                    <div class="mt-8">
                      <SectionFeedback client:load url={section.sectionFeedbackUrl} />
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      <!-- Overall Feedback -->
      {instance.overallFeedbackUrl && (
        <section class="section py-12 md:py-16">
          <div class="container">
            <div class="max-w-4xl mx-auto">
              <h2 class="heading-2 mb-6">How was the workshop overall?</h2>
              <iframe
                src={instance.overallFeedbackUrl}
                width="100%"
                height="500"
                frameborder="0"
                title="Workshop feedback form"
              ></iframe>
            </div>
          </div>
        </section>
      )}

      <!-- Footer Note -->
      <section class="py-8">
        <div class="container">
          <div class="max-w-4xl mx-auto">
            <p class="text-sm text-ink-faint text-center">
              Materials available until {formatCloseDateLong(closeDate)}.
            </p>
          </div>
        </div>
      </section>
    </>
  )}
</BaseLayout>
