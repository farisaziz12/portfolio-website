---
export const prerender = false

import BaseLayout from '../../layouts/BaseLayout.astro';
import { sanityFetch } from '../../lib/sanity/client';
import { allWorkshopInstancesQuery } from '../../lib/sanity/queries';
import { getAccessStatus, getCloseDate } from '../../lib/workshop-access';

interface WorkshopInstanceRow {
  _id: string;
  title: string;
  event: string;
  token: string;
  workshopDate: string;
  accessDurationDays: number;
  forceClose: boolean;
  repoUrl: string;
  overallFeedbackUrl?: string;
  emailCaptureEnabled?: boolean;
}

const ADMIN_PASSWORD = import.meta.env.ADMIN_PASSWORD;

let authError = '';
let isAuthenticated = false;

const sessionCookie = Astro.cookies.get('admin_session')?.value;
if (sessionCookie === 'valid') {
  isAuthenticated = true;
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const password = formData.get('password')?.toString() || '';

  if (ADMIN_PASSWORD && password === ADMIN_PASSWORD) {
    Astro.cookies.set('admin_session', 'valid', {
      httpOnly: true,
      secure: import.meta.env.PROD,
      sameSite: 'strict',
      maxAge: 28800,
      path: '/',
    });
    isAuthenticated = true;
  } else {
    authError = ADMIN_PASSWORD ? 'Incorrect password' : 'ADMIN_PASSWORD env var not set';
  }
}

let instances: WorkshopInstanceRow[] = [];
if (isAuthenticated) {
  instances = await sanityFetch<WorkshopInstanceRow[]>(allWorkshopInstancesQuery).catch(() => []);
}

const statusConfig: Record<string, { label: string; classes: string }> = {
  'open': { label: 'Open', classes: 'bg-emerald-50 dark:bg-emerald-900/20 text-emerald-700 dark:text-emerald-400 border-emerald-200 dark:border-emerald-800' },
  'upcoming': { label: 'Upcoming', classes: 'bg-amber-50 dark:bg-amber-900/20 text-amber-700 dark:text-amber-400 border-amber-200 dark:border-amber-800' },
  'closed': { label: 'Closed', classes: 'bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 border-red-200 dark:border-red-800' },
  'force-closed': { label: 'Force Closed', classes: 'bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 border-red-200 dark:border-red-800' },
};

const formatDate = (dateStr: string) => {
  return new Date(dateStr).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
};
---

<BaseLayout
  title="Admin | Workshop Dashboard"
  description="Workshop instance dashboard"
  pathname="/admin"
>
  <meta slot="head" name="robots" content="noindex, nofollow" />

  {!isAuthenticated ? (
    <section class="min-h-[80vh] flex items-center">
      <div class="container">
        <div class="max-w-sm mx-auto">
          <div class="card p-8">
            <div class="text-center mb-8">
              <div class="terminal max-w-xs mx-auto mb-6">
                <div class="terminal__header">
                  <div class="terminal__dots">
                    <div class="terminal__dot terminal__dot--red"></div>
                    <div class="terminal__dot terminal__dot--yellow"></div>
                    <div class="terminal__dot terminal__dot--green"></div>
                  </div>
                  <span class="terminal__title">admin.sh</span>
                </div>
                <div class="terminal__body">
                  <span class="terminal__prompt">$</span>
                  <span class="terminal__command"> sudo workshop-admin</span>
                  <div class="terminal__output">Password required...</div>
                </div>
              </div>
              <h1 class="heading-3">Admin Login</h1>
            </div>

            {authError && (
              <div class="mb-4 px-4 py-3 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800">
                <p class="text-sm text-red-700 dark:text-red-400 text-center">{authError}</p>
              </div>
            )}

            <form method="POST" class="space-y-4">
              <div>
                <input
                  type="password"
                  name="password"
                  placeholder="Password"
                  autocomplete="current-password"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-edge bg-surface text-ink placeholder-ink-faint focus:outline-none focus:border-accent transition-colors"
                />
              </div>
              <button type="submit" class="btn-primary w-full py-3">
                Sign In
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
  ) : (
    <section class="py-16 md:py-24">
      <div class="container">
        <div class="max-w-5xl mx-auto">
          <!-- Header -->
          <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
            <div>
              <h1 class="heading-2 mb-2">Workshop Instances</h1>
              <p class="text-ink-muted">Manage and monitor workshop access</p>
            </div>
            <div class="flex items-center gap-2 text-sm text-ink-faint">
              <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
              {instances.length} instance{instances.length !== 1 ? 's' : ''}
            </div>
          </div>

          {instances.length === 0 ? (
            <div class="card p-12 text-center">
              <h3 class="heading-3 mb-4">No instances yet</h3>
              <p class="text-ink-muted mb-6">
                Create a workshop instance in Sanity Studio to get started.
              </p>
              <a
                href="https://faziz-dev.sanity.studio"
                target="_blank"
                rel="noopener noreferrer"
                class="btn-primary"
              >
                Open Sanity Studio
              </a>
            </div>
          ) : (
            <div class="space-y-4">
              {instances.map((instance) => {
                const status = getAccessStatus(instance);
                const close = getCloseDate(instance);
                const cfg = statusConfig[status];

                return (
                  <div class="card overflow-hidden">
                    <!-- Status bar -->
                    <div class={`h-1 ${status === 'open' ? 'bg-emerald-500' : status === 'upcoming' ? 'bg-amber-500' : 'bg-red-500'}`}></div>

                    <div class="p-6">
                      <!-- Header -->
                      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6">
                        <div>
                          <h2 class="font-display font-semibold text-lg text-ink">{instance.title}</h2>
                          <p class="text-sm text-ink-muted">{instance.event}</p>
                        </div>
                        <span class={`tag ${cfg.classes}`}>
                          {cfg.label}
                        </span>
                      </div>

                      <!-- Meta grid -->
                      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
                        <div>
                          <p class="text-xs text-ink-faint uppercase tracking-wider mb-1">Workshop Date</p>
                          <p class="text-sm text-ink font-medium">{formatDate(instance.workshopDate)}</p>
                        </div>
                        <div>
                          <p class="text-xs text-ink-faint uppercase tracking-wider mb-1">Close Date</p>
                          <p class="text-sm text-ink font-medium">{formatDate(close.toISOString())}</p>
                        </div>
                        <div>
                          <p class="text-xs text-ink-faint uppercase tracking-wider mb-1">Duration</p>
                          <p class="text-sm text-ink font-medium">{instance.accessDurationDays} days</p>
                        </div>
                      </div>

                      <!-- Access link -->
                      <div class="mb-6">
                        <p class="text-xs text-ink-faint uppercase tracking-wider mb-2">Access Link</p>
                        <button
                          class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-surface-overlay border border-edge hover:border-edge-strong transition-colors font-mono text-xs text-accent cursor-pointer group"
                          data-url={`https://faziz-dev.com/workshops/attend/${instance.token}`}
                          onclick="navigator.clipboard.writeText(this.dataset.url);this.querySelector('.copy-label').textContent='Copied!';setTimeout(()=>this.querySelector('.copy-label').textContent='Click to copy',2000)"
                        >
                          <span>faziz-dev.com/workshops/attend/{instance.token}</span>
                          <span class="copy-label text-ink-faint group-hover:text-ink-muted transition-colors">Click to copy</span>
                        </button>
                      </div>

                      <!-- Actions -->
                      <div class="flex flex-wrap gap-3 pt-4 border-t border-edge">
                        <a
                          href={`/workshops/attend/${instance.token}`}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="btn-ghost text-sm"
                        >
                          Preview
                          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                          </svg>
                        </a>
                        <a
                          href={instance.repoUrl}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="btn-ghost text-sm"
                        >
                          Repo
                          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                          </svg>
                        </a>
                        <a
                          href={`https://faziz-dev.sanity.studio/structure/workshopInstance;${instance._id}`}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="btn-ghost text-sm"
                        >
                          Edit in Sanity
                          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                          </svg>
                        </a>
                      </div>
                    </div>
                  </div>
                )
              })}
            </div>
          )}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
