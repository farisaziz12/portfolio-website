---
import GeneralSubscribe from '../islands/GeneralSubscribe';

const currentYear = new Date().getFullYear();

const socialLinks = [
  {
    name: 'Bluesky',
    href: 'https://bsky.app/profile/farisaziz12.bsky.social',
    icon: 'M5.202 2.857C7.954 4.922 10.913 9.11 12 11.358c1.087-2.247 4.046-6.436 6.798-8.501C20.783 1.366 24 .213 24 3.883c0 .732-.42 6.156-.667 7.037-.856 3.061-3.978 3.842-6.755 3.37 4.854.826 6.089 3.562 3.422 6.299-5.065 5.196-7.28-1.304-7.847-2.97-.104-.305-.152-.448-.153-.327 0-.121-.05.022-.153.327-.568 1.666-2.782 8.166-7.847 2.97-2.667-2.737-1.432-5.473 3.422-6.3-2.777.473-5.899-.308-6.755-3.369C.42 10.04 0 4.615 0 3.883c0-3.67 3.217-2.517 5.202-1.026',
  },
  {
    name: 'GitHub',
    href: 'https://github.com/farisaziz12',
    icon: 'M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z',
  },
  {
    name: 'LinkedIn',
    href: 'https://linkedin.com/in/farisaziz12',
    icon: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
  },
  {
    name: 'X',
    href: 'https://twitter.com/farisaziz12',
    icon: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z',
  },
];

const speakingLinks = [
  { label: 'Speaking', href: '/speaking' },
  { label: 'Talks', href: '/talks' },
  { label: 'Workshops', href: '/workshops' },
  { label: 'Events', href: '/events' },
  { label: 'Invite Me', href: '/invite' },
];

const servicesLinks = [
  { label: 'Services', href: '/services' },
  { label: 'Consulting', href: '/consulting' },
  { label: 'Mentorship', href: '/mentorship' },
];

const footerLinks = [
  { label: 'Blog', href: '/blog' },
  { label: 'Projects', href: '/projects' },
  { label: 'Impact', href: '/impact' },
  { label: 'About', href: '/about' },
  { label: 'Media', href: '/media' },
];

const externalLinks = [
  { label: 'ZurichJS', href: 'https://zurichjs.com' },
  { label: 'MentorCruise', href: 'https://mentorcruise.com/mentor/farisaziz/' },
];
---

<footer class="border-t border-edge mt-auto">
  <div class="container py-12 md:py-16">
    <!-- Main footer content -->
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-10">
      <!-- Brand + Social -->
      <div class="max-w-xs">
        <a href="/" class="font-display font-semibold text-xl text-ink">
          Faris Aziz
        </a>
        <p class="text-secondary mt-3">
          Staff Software Engineer and Conference Speaker. Building resilient systems. Based in Geneva.
        </p>

        <!-- Social links -->
        <div class="flex items-center gap-4 mt-6">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-ink-faint hover:text-ink transition-colors"
              aria-label={social.name}
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d={social.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Navigation links -->
      <div class="flex flex-wrap gap-x-12 gap-y-6">
        <div>
          <h3 class="text-label-sm uppercase tracking-wider text-ink-faint mb-4">
            Speaking
          </h3>
          <ul class="space-y-3">
            {speakingLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-body-sm text-ink-muted hover:text-ink transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h3 class="text-label-sm uppercase tracking-wider text-ink-faint mb-4">
            Services
          </h3>
          <ul class="space-y-3">
            {servicesLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-body-sm text-ink-muted hover:text-ink transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h3 class="text-label-sm uppercase tracking-wider text-ink-faint mb-4">
            Explore
          </h3>
          <ul class="space-y-3">
            {footerLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-body-sm text-ink-muted hover:text-ink transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h3 class="text-label-sm uppercase tracking-wider text-ink-faint mb-4">
            Elsewhere
          </h3>
          <ul class="space-y-3">
            {externalLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-body-sm text-ink-muted hover:text-ink transition-colors inline-flex items-center gap-1"
                >
                  {link.label}
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              </li>
            ))}
            <li>
              <a
                href="/rss.xml"
                class="text-body-sm text-ink-muted hover:text-ink transition-colors inline-flex items-center gap-1"
              >
                RSS Feed
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20 5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z" />
                </svg>
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Subscribe -->
    <div class="mt-10 pt-8 border-t border-edge max-w-md">
      <GeneralSubscribe client:idle compact />
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-edge flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <p class="text-body-sm text-ink-faint">
        &copy; {currentYear} Faris Aziz
      </p>
    </div>
  </div>
</footer>
